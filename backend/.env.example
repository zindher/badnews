# BadNews Backend Environment Variables
# Copy this file as .env and fill in real values before deploying.
# In production these are passed as environment variables (Docker/cloud platform).

# ── Database ──────────────────────────────────────────────────────────────────
Database__ConnectionString=Server=.;Database=BadNews;User Id=sa;Password=YourPassword;TrustServerCertificate=true;

# ── JWT ───────────────────────────────────────────────────────────────────────
Jwt__Secret=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
Jwt__Issuer=BadNews
Jwt__Audience=BadNewsUsers
Jwt__ExpirationMinutes=60

# ── CORS ──────────────────────────────────────────────────────────────────────
AllowedOrigins__0=https://your-frontend-domain.vercel.app

# ── Twilio ────────────────────────────────────────────────────────────────────
Twilio__AccountSid=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
Twilio__AuthToken=your_auth_token
Twilio__PhoneNumber=+1234567890

# ── Mercado Pago ──────────────────────────────────────────────────────────────
MercadoPago__AccessToken=APP_USR-xxxxxxxxxxxx
MercadoPago__PublicKey=APP_USR-xxxxxxxxxxxx

# ── SendGrid ──────────────────────────────────────────────────────────────────
SendGrid__ApiKey=SG.xxxxxxxxxxxx
SendGrid__FromEmail=noreply@badnews.mx
